# USDT Balance API Configuration
# Copy this file to .env and configure for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=app.log

# CORS settings (comma-separated origins)
CORS_ORIGINS=*

# Trusted hosts for production (comma-separated)
TRUSTED_HOSTS=localhost,127.0.0.1,yourdomain.com

# =============================================================================
# BLOCKCHAIN RPC ENDPOINTS
# =============================================================================

# Ethereum RPC endpoint (Required)
# Get API key from: https://infura.io/ or https://alchemy.com/
ETHEREUM_RPC_ENDPOINT=https://mainnet.infura.io/v3/YOUR_API_KEY

# Tron network (mainnet, shasta, nile)
TRON_NETWORK=mainnet

# Solana RPC endpoint
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# RPC timeout in seconds
RPC_TIMEOUT=30

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Health check settings
HEALTH_CHECK_ENABLED=true

# Metrics endpoint
METRICS_ENABLED=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=100

# Request timeout
REQUEST_TIMEOUT=60

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode (never use in production)
DEBUG=false

# Enable API documentation
DOCS_ENABLED=true

# =============================================================================
# EXAMPLE PRODUCTION VALUES
# =============================================================================

# Production Ethereum RPC endpoints:
# ETHEREUM_RPC_ENDPOINT=https://mainnet.infura.io/v3/YOUR_INFURA_API_KEY
# ETHEREUM_RPC_ENDPOINT=https://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_API_KEY
# ETHEREUM_RPC_ENDPOINT=https://eth-mainnet.gateway.pokt.network/v1/lb/YOUR_POKT_ID

# Production Solana RPC endpoints:
# SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
# SOLANA_RPC_ENDPOINT=https://solana-api.projectserum.com
# SOLANA_RPC_ENDPOINT=https://rpc.ankr.com/solana

# Production settings:
# LOG_LEVEL=WARNING
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# TRUSTED_HOSTS=yourdomain.com,app.yourdomain.com
# RELOAD=false
# DEBUG=false