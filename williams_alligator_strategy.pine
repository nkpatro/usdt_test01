//@version=6
strategy(title="AI - Williams Alligator Strategy", shorttitle="AI Alligator Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1, slippage=3)

// Date range inputs
startDate = input(timestamp("01 Jan 2025 00:00 +0000"), title="Start Date")
endDate = input(timestamp("31 Dec 2069 23:59 +0000"), title="End Date")

// Date filter
inDateRange = time >= startDate and time <= endDate

// SMMA function (same as indicator)
smma(src, length) =>
	smma = 0.0
	smma := na(smma[1]) ? ta.sma(src, length) : (smma[1] * (length - 1) + src) / length
	smma

// Alligator parameters (same as indicator)
jawLength = input.int(13, minval=1, title="Jaw Length")
teethLength = input.int(8, minval=1, title="Teeth Length")
lipsLength = input.int(5, minval=1, title="Lips Length")
jawOffset = input(8, title="Jaw Offset")
teethOffset = input(5, title="Teeth Offset")
lipsOffset = input(3, title="Lips Offset")

// Calculate Alligator lines (same as indicator)
jaw = smma(hl2, jawLength)
teeth = smma(hl2, teethLength)
lips = smma(hl2, lipsLength)

// Plot the lines with offset set to 0 to preserve visuals
plot(jaw, "Jaw", offset=0, color=#2962FF)
plot(teeth, "Teeth", offset=0, color=#E91E63)
plot(lips, "Lips", offset=0, color=#66BB6A)

// Trading logic
// Go Long when green line (lips) crosses blue line (jaw) to the upside
longCondition = ta.crossover(lips, jaw) and inDateRange

// Close Long when green line (lips) crosses any of the other two lines to the downside
closeLongCondition = (ta.crossunder(lips, jaw) or ta.crossunder(lips, teeth)) and strategy.position_size > 0

// Execute trades
if longCondition
    strategy.entry("Long", strategy.long)

if closeLongCondition
    strategy.close("Long")